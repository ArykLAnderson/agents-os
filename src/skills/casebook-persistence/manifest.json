      "migration",
      "snapshot",
      "restore",
      "projection_rebuild",
      "module_install",
      "module_retire"
    ],
    "optional_module_lifecycle": "versioned descriptor and exact digest-bound schema assets with non-mutating absent/healthy/incompatible/integrity-unsafe diagnosis, explicit atomic install, immutable idempotent receipts, and data-preserving logical retirement",
    "migration_execution": "verified snapshot-first hard-cutover schema 1 to 3 migration on explicitly authorized disposable stores, or an explicitly human-confirmed live store",
    "snapshot_execution": "L08-W01 exact verified snapshot of one explicitly authorized named disposable store, or an explicitly human-confirmed live store, with durable receipt and explicit custody",
    "restore_execution": "L08-W02 exact verified replacement of one explicitly authorized disposable target with retained verified prior copy and truthful terminal classification",
    "local_access": "ordinary Case, Frame, common, and identity access is workspace-wide by default with optional namespace_ids query narrowing; no view context or policy admission is used",
    "retired_operations": "export/disclosure, observation/checkpoint, impact, integrity, projection, and purge operations fail closed and are not admitted capabilities",
    "typed_read_target": "stable_owner_id without visibility gating",
    "case_revision_assembly": "complete canonical Case create and commit_revision",
    "case_discovery": "exact ID or cross-namespace alias resolve, cohesive read, bounded scan lexical search and explicit-link traversal",
    "frame_revision_assembly": "complete canonical Frame/Discovery/disposition-boundary/Case-disposition create and commit_revision",
    "frame_statuses": [
      "active",
      "completed",
      "abandoned",
      "superseded"
    ],
    "discovery_lifecycles": [
      "active",
      "settled",
      "tombstoned"
    ],
    "discovery_dependencies": "typed stable references",
    "frame_query": "direct current/read/list queries with optional namespace_ids filtering and selector-bound fenced paging",
    "common_subset": "typed resolve/list/bounded lexical search over case/frame normalized records",
    "markdown_profile": "exclusive Markdown installation with full typed reduced common operations, digest-guarded atomic Case replacement, manifest-selected coherent Frame/Discovery/disposition generations, deterministic interchange, and explicit omitted SQLite guarantees",
    "exact_identity": "UUID-based Case frontmatter plus authority-marker-bound digest-verified manifests; typed stable Frame, Discovery, disposition-boundary, Case-disposition, and base-version IDs with exact digest-verified manifest bindings",
    "markdown_local_access": "v2 workspace marker without view; ordinary selected-workspace Case, Frame, and common operations do not require request context"
  },
  "unsupported_until_later_work_items": [
    "case purge publication",
    "case closed-list and broader include/filter/lifecycle-query breadth",
