{
  "runtime_manifest_version": 1,
  "protocol": {
    "id": "casebook-persistence-json",
    "version": 1
  },
  "schema": {
    "id": "casebook-persistence-sqlite",
    "version": 1,
    "store_initialization": "explicit_human_authorized"
  },
  "entrypoint": {
    "interpreter": "node",
    "path": "variants/sqlite/bin/casebook-persistence.mjs",
    "stdout": "versioned-json-only",
    "stderr": "diagnostics-only"
  },
  "supported_operations": [
    "diagnose",
    "initialize_store",
    "get_store_operation_receipt",
    "case.create",
    "case.read",
    "frame.create",
    "frame.read",
    "frame.list"
  ],
  "l01_operation_constraints": {
    "store_receipt_visible_operation_kinds": [
      "initialize_store"
    ],
    "typed_read_target": "stable_owner_id_under_exact_active_view",
    "frame_statuses": [
      "active"
    ],
    "discovery_lifecycles": [
      "active"
    ],
    "discovery_dependencies": "empty_only",
    "frame_list": "active_only_without_filters_history_or_paging"
  }
}
