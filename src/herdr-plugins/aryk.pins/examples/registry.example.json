{
  "_notice": "NON-AUTHORITATIVE EXAMPLE ONLY. A trusted Casebook/Steward publisher must create the machine-local registry.",
  "schemaVersion": 1,
  "route": {
    "sessionName": "casebook-trial",
    "configPath": "/Users/example/.config/herdr/trials/casebook/config.toml",
    "socketPath": "/Users/example/.config/herdr/sessions/casebook-trial/herdr.sock",
    "protocol": 17
  },
  "projects": [
    {
      "canonicalId": "casebook-project:pi-example",
      "generation": 1,
      "reconciliationState": "current",
      "stewardSessionCanonicalId": "agent-conversation:pi-example-steward"
    },
    {
      "canonicalId": "casebook-project:opencode-example",
      "generation": 1,
      "reconciliationState": "current",
      "stewardSessionCanonicalId": "agent-conversation:opencode-example-steward"
    }
  ],
  "sessions": [
    {
      "canonicalId": "agent-conversation:pi-example-steward",
      "projectCanonicalId": "casebook-project:pi-example",
      "generation": 1,
      "reconciliationState": "current",
      "role": "steward",
      "officialAgentSession": {
        "source": "herdr:pi",
        "agent": "pi",
        "kind": "path",
        "value": "/Users/example/.pi/agent/sessions/example.jsonl"
      },
      "binding": {
        "workspaceId": "replaceable-pi-workspace-id",
        "tabId": "replaceable-pi-tab-id",
        "paneId": "replaceable-pi-pane-id",
        "terminalId": "replaceable-pi-terminal-id"
      }
    },
    {
      "canonicalId": "agent-conversation:opencode-example-steward",
      "projectCanonicalId": "casebook-project:opencode-example",
      "generation": 1,
      "reconciliationState": "current",
      "role": "steward",
      "officialAgentSession": {
        "source": "herdr:opencode",
        "agent": "opencode",
        "kind": "id",
        "value": "official-opencode-session-id"
      },
      "binding": {
        "workspaceId": "replaceable-opencode-workspace-id",
        "tabId": "replaceable-opencode-tab-id",
        "paneId": "replaceable-opencode-pane-id",
        "terminalId": "replaceable-opencode-terminal-id"
      }
    }
  ]
}
