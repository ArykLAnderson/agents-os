{
  "targets": [
    "pi",
    "codex",
    "opencode"
  ],
  "skillExcludes": {
    "codex": [
      "coach"
    ]
  },
  "generatedHeader": "<!-- Generated from Agent OS src by scripts/agents-os.mjs. Do not edit directly. -->",
  "globalInstructions": {
    "pi": "~/.pi/agent/AGENTS.md",
    "codex": "~/.codex/AGENTS.md",
    "opencode": "~/.config/opencode/AGENTS.md"
  },
  "adapterSurfaces": {
    "pi": {
      "generateAgents": true,
      "skills": {
        "path": "~/.agents-os/adapters/pi/generated/skills",
        "mode": "configured"
      },
      "agents": {
        "path": "~/.pi/agent/agents/agents-os",
        "mode": "copy",
        "files": [
          "focused-validator.md"
        ]
      },
      "dependencies": [
        "~/.pi/agent/npm/node_modules/pi-subagents/package.json"
      ]
    },
    "codex": {
      "generateAgents": false,
      "skills": {
        "path": "~/.codex/skills",
        "mode": "entries"
      },
      "agents": null,
      "dependencies": []
    },
    "opencode": {
      "generateAgents": true,
      "skills": {
        "path": "~/.config/opencode/skills",
        "mode": "entries"
      },
      "agents": {
        "path": "~/.config/opencode/agent",
        "files": [
          "focused-validator.md"
        ]
      },
      "dependencies": []
    }
  },
  "requiredPublicSkills": [
    "coding-worker",
    "focused-validator",
    "software-implementation"
  ],
  "retiredSkills": [
    "deliver",
    "feature-integration",
    "implement-feature",
    "slice-build",
    "ticket-executor"
  ],
  "scope": "global",
  "scopeRule": "Scope is inferred from the Agent OS root; src internals are identical across global and project roots."
}
